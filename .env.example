# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Email pengirim. Gunakan "onboarding@resend.dev" untuk testing,
# atau alamat di domain yang sudah diverifikasi di Resend untuk production.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email Anda — tujuan notifikasi permintaan CV
OWNER_EMAIL=satria.bagaskara.05@gmail.com

# Secret untuk menandatangani token Approve/Reject (isi dengan string acak yang panjang)
JWT_SECRET=

# URL production deployment, contoh: https://portfolio-satria.vercel.app
SITE_URL=

# Connection string Postgres (Vercel Storage > Postgres, didukung oleh Neon).
# Ambil dari tab ".env.local" di dashboard Vercel setelah database dibuat & di-connect ke project.
POSTGRES_URL=

# Login halaman admin (/admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=
